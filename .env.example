POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinel_db
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=your_secure_password_here

REDIS_HOST=localhost
REDIS_PORT=6379

JWT_SECRET=generate_a_long_random_string_for_production
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440
REFRESH_TOKEN_DAYS=14
PASSWORD_RESET_TOKEN_MINUTES=60
EMAIL_VERIFICATION_TOKEN_MINUTES=60

GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
USER_SERVICE_PORT=8002
DATA_SERVICE_PORT=8003

AUTH_SERVICE_URL=http://auth-service:8001
USER_SERVICE_URL=http://user-service:8002
DATA_SERVICE_URL=http://data-service:8003

CORS_ORIGINS=["http://localhost:3000"]
LOGIN_WINDOW_SEC=300
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_SEC=900
EMAIL_DELIVERY_MODE=file
EMAIL_FROM=no-reply@sentinel.local
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_OUTPUT_DIR=./outbox
AUTH_DEBUG_RETURN_TOKENS=false

RATE_LIMIT_WINDOW_SEC=60
RATE_LIMIT_MAX_REQUESTS=100
